# Samsung Galaxy S20 FE (r8q), Snapdragon SM8250.
CONFIG_DEFAULT_DEVICE_TREE="qcom/sm8250-samsung-r8q"

# Avoid Samsung's stock reserved-memory hole around 0x90400000-0x90a00000.
CONFIG_TEXT_BASE=0x91000000

# r8q boots from UFS, exposed through U-Boot's SCSI block layer.
# MMC fastboot will stare at the wrong damn disk and miss boot_a.
# CONFIG_FASTBOOT_FLASH_MMC is not set
CONFIG_FASTBOOT_FLASH_BLOCK=y
CONFIG_FASTBOOT_FLASH_BLOCK_INTERFACE_NAME="scsi"
CONFIG_FASTBOOT_FLASH_BLOCK_DEVICE_ID=0

# r8q's DTBO table starts with a tiny stub. Retail-ish REV04A is board-id,10.
CONFIG_TOWED_BOOT_ANDROID=y
CONFIG_TOWED_BOOT_ANDROID_DTBO_INDEX=5
CONFIG_TOWED_DEBUG=y
CONFIG_TOWED_DEBUG_ANDROID_CONSOLE="tty0"
CONFIG_TOWED_DEBUG_ANDROID_BOOTARGS="debug ignore_loglevel loglevel=8 initcall_debug no_console_suspend printk.devkmsg=on"
