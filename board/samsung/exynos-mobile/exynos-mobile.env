stdin=serial,button-kbd
stdout=serial,vidconsole
stderr=serial,vidconsole

loadaddr=0x80000000
kernel_addr_r=0x80000000
ramdisk_addr_r=0x88000000
vendor_boot_comp_addr_r=0x90000000

blkmapcmd=blkmap create root;
	  blkmap map root 0 ${blkmap_size_r} linear ${blkmap_blk_ifname} ${blkmap_blk_dev} ${blkmap_blk_nr}

preboot=run blkmapcmd

bootdelay=0
#if CONFIG_TOWED_BOOT_ANDROID
bootcmd=bootefi bootmgr; pause; run towed_android_boot; bootmenu
#else
bootcmd=bootefi bootmgr; pause; bootmenu
#endif

fastbootcmd=echo "Fastboot Mode";
	fastboot -l $fastboot_addr_r usb 0

#if CONFIG_TOWED_BOOT_ANDROID
towed_android_boot=echo "Trying Android/downstream boot";
	setenv _towed_bootmeths ${bootmeths};
	setenv bootmeths android;
	bootflow scan -b;
	if test -n "${_towed_bootmeths}"; then
		setenv bootmeths ${_towed_bootmeths};
	else
		setenv bootmeths;
	fi;
	setenv _towed_bootmeths
#endif

bootmenu_0=Continue Boot=boot
bootmenu_1=Enter Fastboot Mode=run fastbootcmd
bootmenu_2=UEFI Maintenance Menu=eficonfig
bootmenu_3=Reboot=reset
bootmenu_4=Power Off=poweroff
#if CONFIG_TOWED_BOOT_ANDROID
bootmenu_5=Boot Android/downstream=run towed_android_boot; pause
#endif

button_cmd_0_name=Volume Down Key
button_cmd_0=bootmenu
